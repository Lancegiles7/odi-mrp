# ============================================================
# Odi MRP — Environment Variables
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local (never commit .env.local to git)
# 2. Create a project at https://supabase.com
# 3. Go to Project Settings → API
# 4. Copy the values below from your project dashboard
# ============================================================

# Your Supabase project URL
# Found at: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public key
# Found at: Project Settings → API → Project API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# OPTIONAL: Only needed if you are running Supabase CLI locally
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
